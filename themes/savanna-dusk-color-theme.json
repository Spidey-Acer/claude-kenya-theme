  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c544a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc Comments",
      "scope": [
        "comment.block.documentation",
        "comment.block.javadoc"
      ],
      "settings": {
        "foreground": "#6a6258",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#788c5d"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#5da1a3"
      }
    },
    {
      "name": "Template String Expressions",
      "scope": [
        "punctuation.definition.template-expression",
        "string.template punctuation"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#c9956b"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c9956b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Other Constants",
      "scope": [
        "constant.other",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#c9956b"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison"
      ],
      "settings": {
        "foreground": "#b0a89c"
      }
    },
    {
      "name": "Import/Export/Return",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.return",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage Type",
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.interface"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "Storage Modifier",
      "scope": [
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static"
      ],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Name",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#d9aa7a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Arrow Function",
      "scope": [
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "Class Name",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#c9956b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type Name",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#5da1a3"
      }
    },
    {
      "name": "Interface Name",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#5da1a3",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Enum",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#5da1a3"
      }
    },
    {
      "name": "Type Parameter / Generic",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#8b7ec8"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#8b7ec8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.local"
      ],
      "settings": {
        "foreground": "#e8e0d4"
      }
    },
    {
      "name": "Object Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#b0a89c"
      }
    },
    {
      "name": "this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant Variable (UPPER_CASE)",
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#c9956b"
      }
    },
    {
      "name": "HTML Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c9956b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSX Component Tag",
      "scope": [
        "support.class.component",
        "entity.name.tag support.class.component"
      ],
      "settings": {
        "foreground": "#5da1a3"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#c9956b"
      }
    },
    {
      "name": "CSS Selector / Class",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "name": "CSS Pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#8b7ec8"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#c9956b"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "name": "JSON String Value",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#788c5d"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "heading.1.markdown entity.name",
        "heading.2.markdown entity.name",
        "heading.3.markdown entity.name",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
